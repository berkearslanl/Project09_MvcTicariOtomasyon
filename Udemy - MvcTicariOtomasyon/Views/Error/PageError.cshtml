@{
    ViewBag.Title = "404 - Sayfa Bulunamadı";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}

<div class="container-fluid d-flex flex-column align-items-center justify-content-center" style="min-height: 75vh;">
    <div class="text-center">
        <div class="error-icon-box mb-4">
            <span class="display-1 font-weight-bold text-primary animate-pulse" style="font-size: 8rem; letter-spacing: -2px;">404</span>
            <div class="error-icon-wrapper d-inline-block ml-2 text-warning">
                <i class="fas fa-exclamation-triangle fa-4x mb-3 animate-bounce"></i>
            </div>
        </div>

        <h1 class="h2 font-weight-bold text-gray-900 mb-2">
            Olamaz! Sayfa Kaybolmuş Gibi...
        </h1>

        <p class="text-muted mx-auto mb-4" style="max-width: 500px; font-size: 1.1rem; line-height: 1.6;">
            Aradığınız sayfa silinmiş, ismi değiştirilmiş veya geçici olarak kullanılamıyor olabilir.
            Lütfen adresi kontrol edin veya aşağıdaki butonları kullanarak güvenli bölgeye dönün.
        </p>

        <div class="d-flex flex-column flex-sm-row justify-content-center align-items-center">
            <a href="/Kategori/Index" class="btn btn-primary btn-lg shadow-sm font-weight-bold px-4 mb-2 mb-sm-0 mr-sm-3">
                <i class="fas fa-tachometer-alt mr-2"></i> Kontrol Paneline Dön
            </a>
            <button onclick="history.back()" class="btn btn-outline-secondary btn-lg font-weight-bold px-4">
                <i class="fas fa-arrow-left mr-2"></i> Geri Git
            </button>
        </div>
    </div>
</div>

<style>
    .text-gray-900 {
        color: #1a202c !important;
    }

    /* Sayfaya derinlik katmak için hafif bir animasyon pulse efekti */
    .animate-pulse {
        animation: pulse 2s infinite ease-in-out;
    }

    @@keyframes pulse {
        0% {
            transform: scale(1);
        }

        50% {
            transform: scale(1.03);
        }

        100% {
            transform: scale(1);
        }
    }

    /* İkaz ambleminin dikkat çekici hafif sallanma efekti */
    .animate-bounce {
        animation: bounce 2.5s infinite ease-in-out;
    }

    @@keyframes bounce {
        0%, 100% {
            transform: translateY(0);
        }

        50% {
            transform: translateY(-8px);
        }
    }
</style>