@model Udemy___MvcTicariOtomasyon.Models.Entities.Mesaj
@{
    ViewBag.Title = "Mesaj Detayı";
    Layout = "~/Views/Shared/CariLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="mb-4">
        <button onclick="window.history.back();" class="btn btn-sm btn-light border shadow-sm">
            ⬅ Geri Dön
        </button>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white border-bottom py-3">
            <div class="d-flex justify-content-between align-items-start">
                <div>
                    <h3 class="h5 font-weight-bold text-dark mb-1">@Model.Konu</h3>
                    <div class="text-muted" style="font-size: 14px;">
                        <span class="mr-3"><strong>Kimden:</strong> @Model.Gönderici</span>
                        <span><strong>Kime:</strong> @Model.Alici</span>
                    </div>
                </div>
                <div class="text-right">
                    <span class="badge badge-light p-2 border text-muted" style="font-size: 13px;">
                        📅 @Model.Tarih.ToString("dd MMMM yyyy HH:mm")
                    </span>
                </div>
            </div>
        </div>

        <div class="card-body py-4" style="background-color: #fafafa;">
            <div class="p-4 bg-white rounded shadow-sm border" style="min-height: 200px; white-space: pre-line; line-height: 1.6; color: #333;">
                @Model.icerik
            </div>
        </div>

        <div class="card-footer bg-white border-top d-flex justify-content-between align-items-center py-3">
            <div>
                @if (Model.Gönderici != (string)Session["CariMail"])
                {
                    <a href="/CariPanel/MesajGonder?alicimail=@Model.Gönderici" class="btn btn-sm btn-success px-4 font-weight-bold">
                        ↩️ Cevapla
                    </a>
                }
            </div>
            <div>
                <a href="/CariPanel/MesajListesi" class="btn btn-sm btn-outline-primary px-3 mr-1">Gelen Kutusu</a>
                <a href="/CariPanel/GonderilenMesajlar" class="btn btn-sm btn-outline-secondary px-3">Giden Kutusu</a>
            </div>
        </div>
    </div>
</div>