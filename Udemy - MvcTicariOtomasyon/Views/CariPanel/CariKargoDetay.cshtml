@model List<Udemy___MvcTicariOtomasyon.Models.Entities.KargoTakip>
@{
    ViewBag.Title = "Kargo Detay";
    Layout = "~/Views/Shared/CariLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h4 mb-1 text-gray-800">Kargo Takip Detayları</h1>
            <p class="text-muted small mb-0">Takip Numarası: <strong class="text-primary text-monospace">#@ViewBag.takipkodu</strong></p>
        </div>
        <a href="/CariPanel/KargoTakip" class="btn btn-light btn-sm border shadow-sm px-3">
            ← Listeye Dön
        </a>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-header bg-white py-3 border-bottom">
            <h6 class="m-0 font-weight-bold text-secondary">Kargo Gönderi Hareketleri</h6>
        </div>
        <div class="card-body p-4">
            <div class="timeline-wrapper pl-2" style="border-left: 3px solid #e9ecef; position: relative;">

                @if (Model != null && Model.Any())
                {
                    foreach (var x in Model)
                    {
                        <div class="timeline-item mb-4" style="position: relative; padding-left: 20px;">
                            <div style="position: absolute; left: -29px; top: 5px; width: 15px; height: 15px; border-radius: 50%; background-color: #4e73df; border: 3px solid #fff; box-shadow: 0 0 0 3px #e9ecef;"></div>

                            <div class="card bg-light border-0 shadow-none mb-0">
                                <div class="card-body p-3 d-sm-flex justify-content-between align-items-center">
                                    <div class="mb-2 mb-sm-0">
                                        <p class="mb-0 font-weight-normal text-dark">@x.Aciklama</p>
                                    </div>
                                    <div class="text-right">
                                        <span class="badge badge-white border text-secondary px-3 py-2 shadow-sm small">
                                            @(x.TarihZaman != null ? Convert.ToDateTime(x.TarihZaman).ToString("dd.MM.yyyy HH:mm") : "-")
                                        </span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-4 text-muted" style="margin-left: -20px;">
                        <p class="mb-0">Bu kargo koduna ait henüz bir hareket girişi yapılmamıştır.</p>
                    </div>
                }

            </div>
        </div>
    </div>
</div>