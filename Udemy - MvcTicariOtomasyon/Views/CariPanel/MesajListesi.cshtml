@model List<Udemy___MvcTicariOtomasyon.Models.Entities.Mesaj>
@{
    ViewBag.Title = "Gelen Mesajlar";
    Layout = "~/Views/Shared/CariLayout.cshtml";
}
<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 text-gray-800 mb-0">📥 Gelen Mesajlar</h2>
        <div>
            <a href="/CariPanel/MesajGonder" class="btn btn-primary btn-sm font-weight-bold shadow-sm mr-2">
                ✍️ Yeni Mesaj Gönder
            </a>
            <a href="/CariPanel/GonderilenMesajlar" class="btn btn-outline-primary btn-sm font-weight-bold shadow-sm">
                🚀 Gönderilen Mesajlar
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <p class="text-muted mb-0">Gelen kutunuzda herhangi bir mesaj bulunmuyor.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0" style="vertical-align: middle;">
                        <thead class="bg-light text-muted uppercase font-weight-bold" style="font-size: 13px;">
                            <tr>
                                <th class="border-0 pl-4" style="width: 25%;">Gönderici</th>
                                <th class="border-0" style="width: 55%;">Konu / İçerik Öneizleme</th>
                                <th class="border-0 text-right pr-4" style="width: 20%;">Tarih</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr onclick="location.href='@Url.Action("MesajDetay", "CariPanel", new { id = item.MesajId })'" style="cursor: pointer;">
                                    <td class="pl-4 font-weight-bold text-dark">
                                        @item.Gönderici
                                    </td>
                                    <td>
                                        <span class="font-weight-bold text-dark d-block">@item.Konu</span>
                                        <small class="text-muted text-truncate d-block" style="max-width: 500px;">
                                            @(item.icerik.Length > 80 ? item.icerik.Substring(0, 80) + "..." : item.icerik)
                                        </small>
                                    </td>
                                    <td class="text-right pr-4 text-muted" style="font-size: 14px;">
                                        @item.Tarih.ToString("dd MMM yyyy")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>