@model List<Udemy___MvcTicariOtomasyon.Models.Entities.KargoDetay>
@{
    ViewBag.Title = "Kargo Takip";
    Layout = "~/Views/Shared/CariLayout.cshtml";
}

<div class="container-fluid mt-4">
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body py-3 d-sm-flex align-items-center justify-content-between bg-white rounded">
            <h5 class="m-0 font-weight-bold text-primary">Kargolarım</h5>

            <div class="mt-2 mt-sm-0">
                @using (Html.BeginForm("KargoTakip", "CariPanel", FormMethod.Get, new { @class = "form-inline" }))
                {
                    <div class="input-group">
                        @Html.TextBox("p", null, new
                        {
                            @class = "form-control bg-light border-0 small",
                            placeholder = "Takip kodu ara...",
                            style = "border-radius: 0.35rem 0 0 0.35rem;"
                        })
                        <div class="input-group-append">
                            <button type="submit" class="btn btn-primary btn-sm px-3" style="border-radius: 0 0.35rem 0.35rem 0;">
                                Ara
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="min-width: 600px;">
                    <thead class="bg-light text-secondary text-uppercase font-weight-bold small">
                        <tr>
                            <th class="border-0 pl-4 py-3">Takip Kodu</th>
                            <th class="border-0 py-3">Personel</th>
                            <th class="border-0 py-3">Alıcı</th>
                            <th class="border-0 py-3">Tarih</th>
                            <th class="border-0 pr-4 py-3 text-right">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody class="text-dark">
                        @if (Model != null && Model.Any())
                        {
                            foreach (var x in Model)
                            {
                                <tr>
                                    <td class="pl-4 py-3 font-weight-bold text-primary">
                                        <span class="badge badge-light p-2 border text-monospace">#@x.TakipKodu</span>
                                    </td>
                                    <td class="py-3 text-secondary">@x.Personel</td>
                                    <td class="py-3">@x.Alici</td>
                                    <td class="py-3 text-muted small">
                                        @(x.Tarih != null ? Convert.ToDateTime(x.Tarih).ToString("dd.MM.yyyy") : "-")
                                    </td>
                                    <td class="pr-4 py-3 text-right">
                                        <a href="/CariPanel/CariKargoDetay/@x.TakipKodu" class="btn btn-info btn-sm px-3 shadow-sm font-weight-bold">
                                            Detaylar
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">
                                    <p class="mb-0">Kayıtlı kargo bilgisi bulunamadı.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>