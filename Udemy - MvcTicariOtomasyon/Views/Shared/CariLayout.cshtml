@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="description" content="">
    <meta name="author" content="">
    <title>Mvc Ticari Otomasyon - Cari Paneli</title>
    <link href="/webpanel/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
    <link href="/webpanel/css/simple-sidebar.css" rel="stylesheet">

    <style>
        :root {
            --bg-main: #12141c;
            --bg-sidebar: #1a1d29;
            --bg-card: #1f2335;
            --border-color: #2f3549;
            --text-primary: #f8fafc;
            --text-secondary: #94a3b8;
            --accent-color: #3b82f6;
        }

        body {
            background-color: var(--bg-main) !important;
            color: var(--text-primary) !important;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        }

        /* Sidebar Geliştirmeleri */
        #sidebar-wrapper {
            background-color: var(--bg-sidebar) !important;
            border-right: 1px solid var(--border-color) !important;
        }

            #sidebar-wrapper .sidebar-heading {
                background-color: var(--bg-sidebar) !important;
                color: var(--text-primary) !important;
                font-weight: 700;
                border-bottom: 1px solid var(--border-color) !important;
                padding: 1.2rem 1.25rem;
            }

            #sidebar-wrapper .list-group-item {
                background-color: transparent !important;
                color: var(--text-secondary) !important;
                border: none !important;
                padding: 0.85rem 1.5rem;
                transition: all 0.2s ease;
                font-weight: 500;
            }

                #sidebar-wrapper .list-group-item:hover {
                    color: var(--text-primary) !important;
                    background-color: rgba(59, 130, 246, 0.1) !important;
                    padding-left: 1.8rem;
                }

        /* Navbar Geliştirmeleri */
        .navbar {
            background-color: var(--bg-sidebar) !important;
            border-bottom: 1px solid var(--border-color) !important;
        }

            .navbar .nav-link {
                color: var(--text-secondary) !important;
            }

                .navbar .nav-link:hover, .navbar .nav-item.active .nav-link {
                    color: var(--text-primary) !important;
                }

        .dropdown-menu {
            background-color: var(--bg-card) !important;
            border: 1px solid var(--border-color) !important;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3) !important;
        }

        .dropdown-item {
            color: var(--text-secondary) !important;
        }

            .dropdown-item:hover {
                background-color: rgba(59, 130, 246, 0.1) !important;
                color: var(--text-primary) !important;
            }

        .dropdown-divider {
            border-top: 1px solid var(--border-color) !important;
        }

        /* İçerik Sayfalarındaki Sınıfları Ezme (Çatışma Önleyici) */
        .card {
            background-color: var(--bg-card) !important;
            border: 1px solid var(--border-color) !important;
            border-radius: 0.5rem;
        }

        h2, .h4, .text-gray-800 {
            color: var(--text-primary) !important;
        }

        .text-muted, .text-gray-600 {
            color: var(--text-secondary) !important;
        }

        .text-dark {
            color: var(--text-primary) !important;
        }

        /* Tablo Karanlık Mod Uyumu */
        .table {
            color: var(--text-primary) !important;
        }

            .table thead.bg-light {
                background-color: rgba(255, 255, 255, 0.03) !important;
            }

            .table th, .table td {
                border-top: 1px solid var(--border-color) !important;
                border-bottom: 1px solid var(--border-color) !important;
            }

        .table-hover tbody tr:hover {
            background-color: rgba(255, 255, 255, 0.02) !important;
            color: var(--text-primary) !important;
        }

        /* Menü Toggle Butonu Küçüktü, Modernleştirildi */
        #menu-toggle {
            padding: 0.25rem 0.75rem;
            border-radius: 0.375rem;
        }
    </style>
</head>
<body>
    <div class="d-flex" id="wrapper">
        <div class="border-right" id="sidebar-wrapper">
            <div class="sidebar-heading">⚙️ Cari Paneli</div>
            <div class="list-group list-group-flush">
                <a href="/CariPanel/Index" class="list-group-item list-group-item-action">👤 Profilim</a>
                <a href="/CariPanel/Siparislerim" class="list-group-item list-group-item-action">📦 Siparişlerim</a>
                <a href="/CariPanel/KargoTakip" class="list-group-item list-group-item-action">🚚 Kargo Takibi</a>
                <a href="/CariPanel/MesajListesi" class="list-group-item list-group-item-action">
                    📥 Mesajlar (Gelen) <span class="badge badge-warning float-right mt-1">@ViewBag.sayi</span>
                </a>
                <a href="/CariPanel/MesajGonder" class="list-group-item list-group-item-action">✍️ Yeni Mesaj Yaz</a>
                <a href="/Login/CikisYap" class="list-group-item list-group-item-action text-danger">🚪 Çıkış Yap</a>
            </div>
        </div>
        <div id="page-content-wrapper">
            <nav class="navbar navbar-expand-lg navbar-light border-bottom">
                <button class="btn btn-outline-primary" id="menu-toggle">
                    ☰ Menü
                </button>

                <button class="navbar-toggler bg-secondary" type="button" data-toggle="collapse" data-target="#navbarSupportedContent" aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav ml-auto mt-2 mt-lg-0">
                        <li class="nav-item active">
                            <a class="nav-link" href="/CariPanel/Index">Profilim</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/CariPanel/KargoTakip">Kargom Nerede?</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" id="navbarDropdown" role="button" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
                                Hızlı Erişim
                            </a>
                            <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                                <a class="dropdown-item" href="/CariPanel/Siparislerim">Siparişlerim</a>
                                <a class="dropdown-item" href="#">Yardım</a>
                                <div class="dropdown-divider"></div>
                                <a class="dropdown-item text-danger" href="/Login/CikisYap">Çıkış Yap</a>
                            </div>
                        </li>
                    </ul>
                </div>
            </nav>

            <div class="container-fluid py-2">
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="/webpanel/vendor/jquery/jquery.min.js"></script>
    <script src="/webpanel/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script>
        $("#menu-toggle").click(function (e) {
            e.preventDefault();
            $("#wrapper").toggleClass("toggled");
        });
    </script>
</body>
</html>