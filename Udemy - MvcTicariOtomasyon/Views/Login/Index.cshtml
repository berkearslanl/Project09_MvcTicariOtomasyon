@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <title>Mvc - Giriş Yap</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta name="keywords" content="Project Responsive web template, Bootstrap Web Templates, Flat Web Templates, Android Compatible web template,
Smartphone Compatible web template, free webdesigns for Nokia, Samsung, LG, SonyEricsson, Motorola web design" />
    <script type="application/x-javascript">
        addEventListener("load", function() { setTimeout(hideURLbar, 0); }, false);
               function hideURLbar(){ window.scrollTo(0,1); } </script>
    <link href="//fonts.googleapis.com/css?family=Open+Sans:300,300i,400,400i,600,600i,700,700i,800,800i&amp;subset=cyrillic,cyrillic-ext,greek,greek-ext,latin-ext,vietnamese" rel="stylesheet">
    <link href="//fonts.googleapis.com/css?family=Raleway:100,100i,200,200i,300,300i,400,400i,500,500i,600,600i,700,700i,800,800i,900,900i&amp;subset=latin-ext" rel="stylesheet">
    <link href="/weblogin/css/style.css" type="text/css" rel="stylesheet" media="all">
    <link rel="stylesheet" href="/weblogin/css/font-awesome.css">

    <link href="/weblogin/css/popup-box.css" rel="stylesheet" type="text/css" media="all" />
</head>
<body>
    <section class="register">
        <div class="header">
            <div class="logo">
                <a href="#">Giriş Formu</a>
            </div>
            <div class="social">
                <li><a href="#"><span class="fa fa-facebook"></span></a></li>
                <li><a href="#"><span class="fa fa-twitter"></span></a></li>
                <li><a href="#"><span class="fa fa-linkedin"></span></a></li>
                <li><a href="#"><span class="fa fa-google-plus"></span></a></li>
            </div>
            <div class="clear"></div>
        </div>

        <div class="register-full">
            <div class="register-left">
                <div class="register">
                    <p>Tamamlanan Projeler</p>
                    <h1>Projelerinizi Güvenle Yönetin</h1>
                    <h2>Yenilikçi ve Hızlı Çözümler</h2>
                    <p>
                        Gelişmiş yönetim panelimiz sayesinde projelerinizi tek bir noktadan kolayca takip edin.
                        İş akışınızı optimize edin, ekibinizle anlık iletişim kurun ve hedeflerinize daha hızlı ulaşın.
                    </p>
                    <div class="content3">
                        <ul>
                            <li><a class="" href="#"> Firmalar</a></li>
                            <li><a class="read" href="#"> Başlayın</a></li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="register-right">
                <div class="register-in">
                    <a class="book popup-with-zoom-anim button-isi zoomIn animated" data-wow-delay=".5s" href="#small-dialog2">Kayıt Ol »</a>
                </div>
                <div class="register-in middle">
                    <a class="book popup-with-zoom-anim button-isi zoomIn animated" data-wow-delay=".5s" href="#small-dialog">Cari Girişi »</a>
                </div>
                <div class="register-in">
                    <a class="book popup-with-zoom-anim button-isi zoomIn animated" data-wow-delay=".5s" href="#small-dialog1">Personel Girişi »</a>
                </div>
                <div class="clear"> </div>
            </div>
            <div class="clear"> </div>
        </div>
        <p class="agile-copyright">© 2026 Ticari Otomasyon Paneli. Tüm Hakları Saklıdır | Tasarım: <a href="https://w3layouts.com/" target="_blank">W3layouts</a></p>
    </section>
    @Html.Partial("GirisPartial")

    @Html.Partial("PersonelGirisPartial")

    @Html.Action("KayitPartial","Login")

    <script type="text/javascript" src="/weblogin/js/jquery-2.1.4.min.js"></script>
    <script src="/weblogin/js/jquery.magnific-popup.js" type="text/javascript"></script>
    <script>
        $(document).ready(function () {
            $('.popup-with-zoom-anim').magnificPopup({
                type: 'inline',
                fixedContentPos: false,
                fixedBgPos: true,
                overflowY: 'auto',
                closeBtnInside: true,
                preloader: false,
                midClick: true,
                removalDelay: 300,
                mainClass: 'my-mfp-zoom-in'
            });

        });
    </script>
</body>
</html>