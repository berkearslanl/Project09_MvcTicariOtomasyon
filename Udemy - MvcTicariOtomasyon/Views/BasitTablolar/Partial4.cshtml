@model IEnumerable<Udemy___MvcTicariOtomasyon.Models.Entities.SinifGrup3>
<div class="card">
    <div class="card-header">
        <h3 class="card-title">Ürün Marka Tablosu</h3>
    </div>
    <div class="card-body p-0">
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Marka</th>
                    <th>Progress Bar</th>
                    <th style="width: 40px">Toplam</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var x in Model)
                {
                    int sonSayi = x.Sayi * 10;
                    <tr>
                        <td>@x.Marka</td>
                        <td>
                            <div class="progress progress-xs">
                                <div class="progress-bar bg-info" style="width: @sonSayi%"></div>
                            </div>
                        </td>
                        <td><span class="badge bg-warning">@x.Sayi</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>